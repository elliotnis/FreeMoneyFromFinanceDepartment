# MongoDB (required for local dev without Docker Compose)
# Local MongoDB:
# MONGODB_URL=mongodb://localhost:27017
# MongoDB Atlas or other hosted:
# MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# Optional
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ---- Passwordless email login (HKUST magic link) ----
# Required for the "Sign in with HKUST email" flow. Use a Gmail account and a
# Gmail App Password (https://myaccount.google.com/apppasswords) — NOT your
# normal Gmail password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASSWORD=your-16-char-gmail-app-password
# SMTP_FROM=HKUST FINA Portal <your-gmail@gmail.com>
# Public URL of the frontend (used to build the magic-link). Override in prod.
# FRONTEND_URL=http://localhost:5173
# How long magic links stay valid (minutes). Default 15.
# MAGIC_LINK_TTL_MINUTES=15

# ---- Admins for the Classes feature ----
# Comma-separated emails allowed to create / cancel classes.
# ADMIN_EMAILS=alice@connect.ust.hk,bob@connect.ust.hk
